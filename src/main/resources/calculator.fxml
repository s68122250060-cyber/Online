<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.online.CalculatorController">

    <TextField fx:id="num1" promptText="Number 1"/>
    <TextField fx:id="num2" promptText="Number 2"/>
    <TextField fx:id="result" promptText="Result"/>

    <HBox spacing="10">
        <Button text="+" onAction="#add"/>
        <Button text="-" onAction="#subtract"/>
        <Button text="*" onAction="#multiply"/>
        <Button text="/" onAction="#divide"/>
    </HBox>

</VBox>